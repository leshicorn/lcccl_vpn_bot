rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gibbonsleday@gmail.com' && request.auth.token.email_verified == true
        // Or check a specific admins collection
        // || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUserMapping(data) {
      return data.keys().hasAll(['nickname', 'telegramId']) &&
             data.keys().size() == 2 &&
             data.nickname is string && data.nickname.size() <= 50 &&
             data.telegramId is int;
    }

    function isValidVpnConfig(data) {
      return data.keys().hasAll(['nickname', 'device', 'content', 'fileName', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.nickname is string && data.nickname.size() <= 50 &&
             data.device is string && data.device.size() <= 50 &&
             data.content is string && data.content.size() <= 1048576 && // 1MB limit
             data.fileName is string && data.fileName.size() <= 100 &&
             data.updatedAt is timestamp && data.updatedAt == request.time;
    }

    // Rules for Mappings
    match /mappings/{nickname} {
      allow read: if isSignedIn(); // Users need to check if they are registered (or the bot does)
      allow write: if isAdmin() && isValidUserMapping(incoming());
    }

    // Rules for Configs
    match /configs/{configId} {
      // allow read: if isAdmin() || (isSignedIn() && existing().nickname == get(/databases/$(database)/documents/mappings_by_tg/$(request.auth.uid)).data.nickname);
      // To keep it simple and follow "Query Enforcer":
      allow list: if isSignedIn() && (isAdmin() || resource.data.nickname == getNicknameForAuthUser());
      allow get: if isSignedIn() && (isAdmin() || resource.data.nickname == getNicknameForAuthUser());
      
      allow create: if isAdmin() && isValidVpnConfig(incoming());
      allow update: if isAdmin() && isValidVpnConfig(incoming()) && 
                    incoming().nickname == existing().nickname; // Cannot change owner
      allow delete: if isAdmin();
    }

    // Helper to get nickname based on TG ID
    // Note: This assumes we have a reverse mapping collection or a queryable field.
    // For rules, it's easier if we have /users/{uid} storing the nickname.
    function getNicknameForAuthUser() {
      // This is a placeholder. In a real app, we'd map Firebase UID to Nickname.
      // Since it's a bot, the bot's server handles the mapping logic.
      return 'none'; 
    }
  }
}
